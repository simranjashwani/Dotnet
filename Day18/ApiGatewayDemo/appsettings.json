{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "customerRoute": {
        "ClusterId": "customers",
        "Match": {
          "Path": "/customer/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/customer"
          },
          {
            "PathPrefix": "/api/v1/customer"
          }
        ]
      },
      "quotationRoute": {
        "ClusterId": "quotations",
        "Match": {
          "Path": "/quotation/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/quotation"
          },
          {
            "PathPrefix": "/api/v1/quotation"
          }
        ]
      }
    },
    "Clusters": {
      "customers": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "customerDestination1": {
            "Address": "http://localhost:5001/"
          },
          "customerDestination2": {
            "Address": "http://localhost:5002/"
          },
          "customerDestination3": {
            "Address": "http://localhost:5003/"
          },
          "customerDestination4": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "quotations": {
        "LoadBalancingPolicy": "RoundRobin",
        "Destinations": {
          "quotationDestination1": {
            "Address": "http://localhost:5005/"
          },
          "quotationDestination2": {
            "Address": "http://localhost:5006/"
          }
        }
      }
    }
  }
}